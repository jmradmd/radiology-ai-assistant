# =============================================================================
# Radiology AI Assistant Environment Variables
# Copy this file to .env and fill in real values:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# Used by: Prisma ORM (packages/db/prisma/schema.prisma)
# Docker default: postgresql://postgres:postgres@localhost:5432/rad_assist
# For Supabase hosted: use the connection string from your Supabase project
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rad_assist
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/rad_assist

# -----------------------------------------------------------------------------
# Supabase Auth & Realtime
# Used by: packages/api/src/context.ts, apps/web/src/lib/supabase/client.ts
# Get from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# -----------------------------------------------------------------------------
# OpenAI (REQUIRED — used for embeddings, always needed regardless of chat model)
# Used by: apps/web/src/lib/rag/search.ts (text-embedding-3-small)
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...your-openai-key

# -----------------------------------------------------------------------------
# Anthropic Claude (optional — premium chat model)
# Used by: packages/api/src/lib/llm-client.ts
# Get from: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...your-anthropic-key

# -----------------------------------------------------------------------------
# DeepSeek (optional — DeepSeek R1 reasoning model)
# Used by: packages/api/src/lib/llm-client.ts
# Get from: https://platform.deepseek.com/api_keys
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-...your-deepseek-key

# -----------------------------------------------------------------------------
# Moonshot / Kimi (optional — fast multimodal chat model)
# Used by: packages/api/src/lib/llm-client.ts
# Get from: https://platform.moonshot.ai
# -----------------------------------------------------------------------------
MOONSHOT_API_KEY=sk-...your-moonshot-key

# -----------------------------------------------------------------------------
# Google Gemini (optional — fast interactive multimodal-friendly chat model)
# Used by: packages/api/src/lib/llm-client.ts (OpenAI-compatible endpoint)
# Get from: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIza...your-gemini-key

# -----------------------------------------------------------------------------
# MiniMax (optional — long-context, cost-efficient high-throughput chat model)
# Used by: packages/api/src/lib/llm-client.ts (OpenAI-compatible endpoint)
# Get from: https://platform.minimax.io/user-center/basic-information/interface-key
# -----------------------------------------------------------------------------
MINIMAX_API_KEY=sk-...your-minimax-key

# -----------------------------------------------------------------------------
# Local LLM (LM Studio / Ollama)
# Point to your local inference server. No API key needed.
# LM Studio default: http://localhost:1234/v1
# Ollama default:    http://localhost:11434/v1
# Remote Mac Studio: http://192.168.x.x:1234/v1
# -----------------------------------------------------------------------------
LOCAL_LLM_URL=http://localhost:1234/v1

# -----------------------------------------------------------------------------
# Policies directory (optional — overrides default PDF folder paths)
# Used by: apps/web/src/app/api/policies/[filename]/route.ts
# Defaults: ./institution-a-policies, ./institution-b-policies
# -----------------------------------------------------------------------------
# POLICIES_DIR=./institution-a-policies

# -----------------------------------------------------------------------------
# Teams standard docs directory (optional — override teams document source directory)
# Used by: scripts/ingest-teams-docs.ts
# Default: ./teams_standard_docs
# -----------------------------------------------------------------------------
# TEAMS_STANDARD_DOCS_DIR=./teams_standard_docs

# -----------------------------------------------------------------------------
# Next.js (optional)
# PORT: dev server port (default 3000)
# NEXT_DISABLE_ERROR_OVERLAY: suppress error overlay in dev
# -----------------------------------------------------------------------------
# PORT=3000
# NEXT_DISABLE_ERROR_OVERLAY=true

# -----------------------------------------------------------------------------
# Apple Notarization (optional — only for macOS desktop app signing)
# Used by: apps/desktop/scripts/notarize.js
# -----------------------------------------------------------------------------
# APPLE_ID=your-apple-id@example.com
# APPLE_ID_PASSWORD=app-specific-password
# APPLE_TEAM_ID=YOUR_TEAM_ID

# -----------------------------------------------------------------------------
# Azure AD (Planned — not yet implemented)
# For future SSO/OIDC integration
# -----------------------------------------------------------------------------
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# -----------------------------------------------------------------------------
# Twilio (Planned — not yet implemented)
# For future SMS notification support
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
