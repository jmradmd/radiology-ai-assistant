{
  "name": "@rad-assist/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "echo 'Error: electron-builder not configured. Install it first: npm i -D electron-builder'",
    "package:mac": "echo 'Error: electron-builder not configured. Install it first: npm i -D electron-builder'",
    "package:win": "echo 'Error: electron-builder not configured. Install it first: npm i -D electron-builder'"
  },
  "dependencies": {
    "@rad-assist/shared": "*",
    "@tanstack/react-query": "^5.17.0",
    "@trpc/client": "^11.0.0-rc.0",
    "@trpc/react-query": "^11.0.0-rc.0",
    "electron-store": "^8.1.0",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "superjson": "^2.2.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
